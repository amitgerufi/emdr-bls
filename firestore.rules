rules_version = '2';

// EMDR BLS — Cloud Firestore security rules.
// Firestore holds only therapist-side data: the therapist profile
// (therapists/{uid} = { pin, createdAt }) and their saved presets
// (therapists/{uid}/presets/{presetId}). The patient (Quest) client never
// touches Firestore. Everything is owner-scoped: a therapist may read/write
// only documents under their own uid. All other paths are denied by default.
service cloud.firestore {
  match /databases/{database}/documents {

    match /therapists/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /presets/{presetId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}

# Firebase Web config for project "emdr-bls-b9cd1".
# Copy this file to ".env.local" and fill in the values from:
#   Firebase Console → Project settings → General → Your apps → Web app → SDK setup and configuration
# These NEXT_PUBLIC_* values are exposed to the browser by design (Firebase web
# config is not a secret; access is enforced by Auth + Security Rules).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=emdr-bls-b9cd1.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://emdr-bls-b9cd1-default-rtdb.firebaseio.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=emdr-bls-b9cd1
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=emdr-bls-b9cd1.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
